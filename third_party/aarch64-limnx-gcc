#!/bin/bash
# Wrapper GCC for cross-compiling against musl for Limnx ARM64
MUSL=/Users/kursataydemir/limnr/limnx/third_party/musl-install-arm64
exec aarch64-elf-gcc -nostdlib \
    -isystem "$MUSL/include" \
    "$MUSL/lib/crt1.o" "$MUSL/lib/crti.o" \
    "$@" \
    -L"$MUSL/lib" -lc -lgcc \
    "$MUSL/lib/crtn.o"
